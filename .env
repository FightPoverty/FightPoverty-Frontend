# JWT 密鑰（生產環境請使用強密碼）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-2024
JWT_REFRESH_SECRET=your-refresh-token-secret-key-change-this-in-production-2024

# Token 過期時間
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server 設定
PORT=3001
NODE_ENV=development

# CORS 設定
CLIENT_URL=http://localhost:5173

# QR Code 掃描網址（用 ngrok 測試時設成 ngrok 網址，掃出來的連結才會正確）
VITE_PUBLIC_URL=https://unnormalized-noncommunistically-dangelo.ngrok-free.dev
